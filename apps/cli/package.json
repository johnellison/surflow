{
  "name": "@surflow/cli",
  "version": "0.0.1",
  "private": true,
  "bin": {
    "surf": "./src/index.ts"
  },
  "scripts": {
    "surf": "tsx src/index.ts",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/surf.cjs --external:node:*",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@surflow/surf-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.25",
    "tsx": "^4",
    "typescript": "^5.7"
  }
}
